#!/usr/bin/env bash
set -euo pipefail

command=${1:-}

pick_underkeys() {
  local used_keys=''

  tmux list-sessions -F '#{session_name}' \
    | while IFS= read -r session_name; do
      local session_lower=${session_name,,}
      local key=''

      for ((i = 0; i < ${#session_name}; i++)); do
        local char=${session_lower:i:1}

        if [[ $char =~ [a-z0-9] && $used_keys != *"$char"* ]]; then
          key=$char
          used_keys+=$char
          break
        fi
      done

      printf '%s\t%s\n' "$key" "$session_name"
    done
}

switch_session() {
  local wanted_key=${1,,}

  while IFS=$'\t' read -r key session_name; do
    if [[ $key == "$wanted_key" ]]; then
      tmux switch-client -t "$session_name"
      return 0
    fi
  done < <(pick_underkeys)
}

case "$command" in
  switch)
    switch_session "${2:-}"
    ;;
  keys)
    pick_underkeys
    ;;
  *)
    echo "Usage: underkeys switch <key> | keys" >&2
    exit 2
    ;;
esac
