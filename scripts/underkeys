#!/usr/bin/env bash
set -euo pipefail

command=${1:-}

pick_underkeys() {
  local used_keys=''

  tmux list-sessions -F '#{session_name}' \
    | while IFS= read -r session_name; do
      local session_lower=${session_name,,}
      local key=''
      local index=-1

      for ((i = 0; i < ${#session_name}; i++)); do
        local char=${session_lower:i:1}

        if [[ $char =~ [a-z0-9] && $used_keys != *"$char"* ]]; then
          key=$char
          index=$i
          used_keys+=$char
          break
        fi
      done

      printf '%s\t%s\t%s\n' "$key" "$index" "$session_name"
    done
}

status() {
  local current_session=${1:-}
  local current_style=${2:-fg=blue,bold}
  local other_style=${3:-fg=white}

  pick_underkeys \
    | while IFS=$'\t' read -r _key index session_name; do
      if [[ "$session_name" == "$current_session" ]]; then
        style=$current_style
      else
        style=$other_style
      fi

      printf '#[%s]' "$style"

      if [[ $index -ge 0 ]]; then
        printf '%s' "${session_name:0:index}"
        printf '#[underscore]%s#[nounderscore,%s]' "${session_name:index:1}" "$style"
        printf '%s' "${session_name:index + 1}"
      else
        printf '%s' "$session_name"
      fi

      printf '#[default] '
    done
}

switch_session() {
  local wanted_key=${1,,}

  while IFS=$'\t' read -r key _index session_name; do
    if [[ $key == "$wanted_key" ]]; then
      tmux switch-client -t "$session_name"
      return 0
    fi
  done < <(pick_underkeys)
}

case "$command" in
  status)
    status "${2:-}" "${3:-fg=blue,bold}" "${4:-fg=white}"
    ;;
  switch)
    switch_session "${2:-}"
    ;;
  keys)
    pick_underkeys
    ;;
  *)
    echo "Usage: underkeys status [current-session] [current-style] [style] | switch <key> | keys" >&2
    exit 2
    ;;
esac
